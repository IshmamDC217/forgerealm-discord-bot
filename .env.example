# Discord
DISCORD_TOKEN=your-bot-token
DISCORD_CLIENT_ID=your-client-id
DISCORD_GUILD_ID=your-guild-id

# Discord channels
CHANNEL_SHOP=123456789012345678
CHANNEL_WEBSITE=123456789012345678
CHANNEL_GENERAL=123456789012345678

# ForgeRealm
FORGEREALM_API_URL=https://api.forgerealm.co.uk
FORGEREALM_SITE_URL=https://forgerealm.co.uk

# MySQL (same credentials as ForgeRealm backend)
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=forgerealm

# Groq AI
GROQ_API_KEY=your-groq-api-key

# Google (service account with Calendar + Sheets + Drive scopes)
GOOGLE_SERVICE_ACCOUNT=base64-encoded-service-account-json
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com

# Permissions — comma-separated Discord user IDs who can delete products
ADMIN_USER_IDS=447033110773628930,535658393562775562

# Polling intervals (ms)
POLL_DATABASE_MS=60000
POLL_WEBSITE_MS=300000
POLL_API_HEALTH_MS=180000
NUDGE_INTERVAL_MS=345600000
